# F5 Distributed Cloud tenant name (e.g. "mycompany")
# Builds base URL: https://{tenant}.console.ves.volterra.io
F5_XC_TENANT=

# Override the base URL directly (optional — takes precedence over tenant)
F5_XC_BASE_URL=

# F5 XC API token — generate at: Console → Account → API Tokens
F5_XC_API_TOKEN=

# Default namespace for operations (default: system)
F5_XC_DEFAULT_NAMESPACE=system

# Dry-run mode — set to "false" to enable live API calls (default: true = safe mode)
F5_XC_DRY_RUN=true

# Transport: "stdio" for local (Claude Code/Copilot), "http" for remote deployment
TRANSPORT=stdio

# HTTP port when TRANSPORT=http (default: 3000)
PORT=3000
